{
  "name": "scholarai-backend",
  "version": "1.0.0",
  "description": "ScholarAI backend - research paper platform with AI summarization and chat",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "node --loader ts-node/esm src/seed.ts"
  },
  "dependencies": {
    "better-auth": "^1.4.2",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "groq-sdk": "^0.9.1",
    "mongoose": "^8.9.5",
    "multer": "^2.0.1",
    "pdf-parse": "^1.1.1",
    "@vercel/node": "^3.2.24"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
